<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Passing_Threshold_Must_Be_Le_Max_Score</fullName>
    <active>true</active>
    <description>Passing Threshold must be less than or equal to Max Score.</description>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Passing_Threshold__c)),
    NOT(ISBLANK(Max_Score__c)),
    Passing_Threshold__c &gt; Max_Score__c
)</errorConditionFormula>
    <errorMessage>Passing Threshold cannot exceed Max Score.</errorMessage>
</ValidationRule>
