    <decisions>
        <name>Candidate_found</name>
        <label>Candidate found?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_no_candidate</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Candidate.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_application</targetReference>
            </connector>
            <label>Candidate Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Upcoming_Interview</name>
        <label>Is Upcoming Interview?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_interviews</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_interviews.Interview_Date__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>nextInterviewDateAssignment</targetReference>
            </connector>
            <label>True</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>applicationBlockFormula</name>
        <dataType>String</dataType>
        <expression>&quot;- &quot; &amp;
{!Loop_Applications.Name} &amp;
&quot; — &quot; &amp;
TEXT({!Loop_Applications.StageName}) &amp;
BR() &amp;
&quot;Interviews:&quot; &amp;
BR() &amp;
{!interviewList} &amp;
BR()</expression>
    </formulas>
    <formulas>
        <name>applicationListFormula</name>
        <dataType>String</dataType>
        <expression>{!applicationList} &amp;
{!applicationBlock} &amp;
BR()</expression>
    </formulas>
    <formulas>
        <name>interviewLineFormula</name>
        <dataType>String</dataType>
        <expression>{!interviewList} &amp;
&quot;- &quot; &amp;
{!Loop_interviews.Name} &amp;
&quot; — &quot; &amp;
TEXT({!Loop_interviews.Interview_Date__c}) &amp;
BR()</expression>
    </formulas>
    <formulas>
        <name>nextInterviewInfoFormula</name>
        <dataType>String</dataType>
        <expression>TEXT({!Loop_interviews.Interview_Type__c}) &amp;
&quot; for &quot; &amp;
{!Loop_Applications.Name} &amp;
&quot; on &quot; &amp;
TEXT(DATEVALUE({!Loop_interviews.Interview_Date__c}))</expression>
    </formulas>
    <formulas>
        <name>noCandidateSummary</name>
        <dataType>String</dataType>
        <expression>&quot;No candidate was found with that name.&quot;</expression>
    </formulas>
    <formulas>
        <name>Summary</name>
        <dataType>String</dataType>
        <expression>&quot;Candidate Summary:&quot; &amp; BR() &amp;
&quot;Name: &quot; &amp; {!Get_Candidate.Name} &amp; BR() &amp;
&quot;Email: &quot; &amp; {!Get_Candidate.Email} &amp; BR() &amp; BR() &amp;
&quot;Next Interview:&quot; &amp; BR() &amp;
{!nextInterviewInfo} &amp; BR() &amp; BR() &amp;
&quot;Applications:&quot; &amp; BR() &amp;
{!applicationList}</expression>
    </formulas>
    <interviewLabel>Get_Candidate_Summary_For_Agent {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Get_Candidate_Summary_For_Agent</label>
    <loops>
        <name>Loop_Applications</name>
        <label>Loop Applications</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_application</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Reset_temp_Text</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Assign_info</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_interviews</name>
        <label>Loop interviews</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Interviews_for_each_application</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Append_Interview_Line</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Build_Application_Block</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
