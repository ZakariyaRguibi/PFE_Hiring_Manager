    <assignments>
        <name>Add_Interview_Stage_Weight</name>
        <label>Add Interview Stage Weight</label>
        <locationX>780</locationX>
        <locationY>700</locationY>
        <assignmentItems>
            <assignToReference>stageCount</assignToReference>
            <operator>Add</operator>
            <value>
                <numberValue>1</numberValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>totalStageWeight</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_Interview_Stages.Stage_Weight__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Interview_Stages</targetReference>
        </connector>
    </assignments>

    <decisions>
        <name>Check_Requested_Action</name>
        <label>Check Requested Action</label>
        <locationX>620</locationX>
        <locationY>260</locationY>
        <defaultConnector>
            <targetReference>Screen_Invalid_Action</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Invalid Action</defaultConnectorLabel>

        <rules>
            <name>Action_Is_Publish</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>actionType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Publish</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Screen_Publish_Confirm</targetReference>
            </connector>
            <label>Publish</label>
        </rules>

        <rules>
            <name>Action_Is_Close</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>actionType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Close</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Close_Allowed</targetReference>
            </connector>
            <label>Close</label>
        </rules>

        <rules>
            <name>Action_Is_Cancel</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>actionType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancel</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Screen_Cancel_Confirm</targetReference>
            </connector>
            <label>Cancel</label>
        </rules>

        <rules>
            <name>Action_Is_Reopen</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>actionType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Reopen</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Reopen_Allowed</targetReference>
            </connector>
            <label>Reopen</label>
        </rules>
    </decisions>

    <decisions>
        <name>Check_Publishing_Requirements</name>
        <label>Check Publishing Requirements</label>
        <locationX>620</locationX>
        <locationY>900</locationY>
        <defaultConnector>
            <targetReference>Screen_Publish_Error</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Invalid Publish Configuration</defaultConnectorLabel>

        <rules>
            <name>Publishing_Configuration_Is_Valid</name>
            <conditionLogic>and</conditionLogic>

            <conditions>
                <leftValueReference>jobPosition.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Draft</stringValue>
                </rightValue>
            </conditions>

            <conditions>
                <leftValueReference>jobPosition.Title__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>

            <conditions>
                <leftValueReference>jobPosition.Portal_Description__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>

            <conditions>
                <leftValueReference>jobPosition.Application_Deadline__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>

            <conditions>
                <leftValueReference>jobPosition.Application_Deadline__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>

            <conditions>
                <leftValueReference>stageCount</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0</numberValue>
                </rightValue>
            </conditions>

            <conditions>
                <leftValueReference>totalStageWeight</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>100</numberValue>
                </rightValue>
            </conditions>

            <connector>
                <targetReference>Update_Status_Open</targetReference>
            </connector>
            <label>Valid Configuration</label>
        </rules>
    </decisions>

    <decisions>
        <name>Check_Close_Allowed</name>
