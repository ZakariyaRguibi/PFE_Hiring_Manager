        </rules>
    </decisions>

    <decisions>
        <name>Check_New_Reopen_Deadline</name>
        <label>Check New Reopen Deadline</label>
        <locationX>1120</locationX>
        <locationY>860</locationY>
        <defaultConnector>
            <targetReference>Screen_Reopen_Deadline_Error</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Invalid New Deadline</defaultConnectorLabel>

        <rules>
            <name>New_Deadline_Is_Valid</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>New_Application_Deadline</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Deadline_And_Open</targetReference>
            </connector>
            <label>New Deadline Valid</label>
        </rules>
    </decisions>

    <description>One screen flow launched from Job Position buttons. It handles Publish, Close, Cancel, and Reopen using the actionType input parameter.</description>
